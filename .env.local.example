# AI Provider: "openrouter" (default) or "xai" (direct xAI API)
# OpenRouter routes through openrouter.ai and supports all models (Grok, Claude, GPT, Gemini)
# xAI routes Grok models directly to api.x.ai (non-Grok models fall back to OpenRouter)
AI_PROVIDER=openrouter

# OpenRouter API key for LLM calls (always required — used for embeddings, audio/vision even when AI_PROVIDER=xai)
OPENROUTER_API_KEY=sk-or-v1-...

# xAI API key for direct Grok access (required when AI_PROVIDER=xai)
# Get your key at https://console.x.ai
XAI_API_KEY=xai-...

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ElevenLabs API key for text-to-speech (optional)
ELEVENLABS_API_KEY=sk_...

# App URL (for OpenRouter referer header)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (for pricing & subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create in Stripe Dashboard)
# Product "openLesson Regular" — $4.99/month recurring
STRIPE_PRICE_REGULAR=price_...
# Product "openLesson Pro" — $14.99/month recurring
STRIPE_PRICE_PRO=price_...
# Product "Extra Lesson" — $1.99 one-time
STRIPE_PRICE_EXTRA=price_...
